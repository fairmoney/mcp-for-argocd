      "hono": "^4.12.25",
      "fast-uri": "^3.1.2",
      "ip-address": "^10.1.1",
      "rollup": "^4.59.0",
      "flatted": "^3.4.2",
      "@eslint/plugin-kit": "^0.3.4",
      "js-yaml": "^4.2.0",
      "glob": "^10.5.0",
      "glob>minimatch": "^9.0.7",
      "@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
      "minimatch@9>brace-expansion": "^2.0.3",
      "eslint>ajv": "^6.14.0",
      "eslint>minimatch": "^3.1.4",
